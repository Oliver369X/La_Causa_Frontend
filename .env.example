# Variables de entorno — frontend Next.js
#
# ── Una sola URL de API ──────────────────────────────────
# El cliente axios usa NEXT_PUBLIC_API_URL en local y en producción (build + navegador).
# Sin borrar slashes finales innecesarios (el código normaliza).
#
# LOCAL (next dev):
#   NEXT_PUBLIC_API_URL=http://localhost:8000
# PRODUCCIÓN / Docker (valor HTTPS público del FastAPI):
#   NEXT_PUBLIC_API_URL=https://api.lacausa.aura.ia.bo

NEXT_PUBLIC_API_URL=http://localhost:8000

# ── Middleware / cookies (solo servidor Next, NO va al bundle público como NEXT_PUBLIC_*)

# Generar con: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=reemplazar-con-la-misma-clave-del-backend

# ── Live E2E (sin mocks) ──────────────────────────────────
# Usar un usuario organizador real con plan de pago y org de pruebas.
E2E_MODE=real
E2E_TARGET=local
E2E_BASE_URL=http://localhost:3001
E2E_BACKEND_URL=http://localhost:8000
LIVE_AGENT_EMAIL=organizer.live@lacausa.dev
LIVE_AGENT_PASSWORD=reemplazar
LIVE_AGENT_ORG_ID=uuid-org-de-pruebas
