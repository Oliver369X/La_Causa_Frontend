# Variables de entorno para el frontend

# URL base del backend API (sin trailing slash)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Entorno (development | production)
NODE_ENV=development

# Debe coincidir exactamente con JWT_SECRET_KEY del backend
# Generar con: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=reemplazar-con-la-misma-clave-del-backend

# ── Live E2E (sin mocks) ──────────────────────────────────
# Usar un usuario organizador real con plan de pago y org de pruebas.
E2E_MODE=real
E2E_TARGET=local
E2E_BASE_URL=http://localhost:3001
E2E_BACKEND_URL=http://localhost:8000
LIVE_AGENT_EMAIL=organizer.live@lacausa.dev
LIVE_AGENT_PASSWORD=reemplazar
LIVE_AGENT_ORG_ID=uuid-org-de-pruebas
